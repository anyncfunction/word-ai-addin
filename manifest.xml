<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:type="TaskPaneApp">
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0</Version>
  <ProviderName>AI Word</ProviderName>
  <DefaultLocale>zh-CN</DefaultLocale>
  <DisplayName DefaultValue="AI 写作助手" />
  <Description DefaultValue="AI 驱动的 Word 文档生成插件，支持续写、改写、全文生成等功能" />
   <IconUrl DefaultValue="https://localhost:3000/assets/icon-32.svg" />
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/assets/icon-80.svg" />
  <SupportUrl DefaultValue="https://github.com/user/word-ai-addin" />
  <AppDomains>
    <AppDomain>localhost</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Document" />
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://localhost:3000/src/index.html" />
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title" />
            <Description resid="GetStarted.Description" />
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl" />
          </GetStarted>
          <FunctionFile resid="Commands.Url" />
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <CustomTab id="AITab">
              <Group id="AIGroup">
                <Label resid="Group.Label" />
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16" />
                  <bt:Image size="32" resid="Icon.32x32" />
                  <bt:Image size="80" resid="Icon.80x80" />
                </Icon>
                <Control xsi:type="Button" id="OpenSidebar">
                  <Label resid="Sidebar.Button.Label" />
                  <Supertip>
                    <Title resid="Sidebar.Button.Label" />
                    <Description resid="Sidebar.Button.Description" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>Office.Sidebar</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>
              </Group>
              <Label resid="CustomTab.Label" />
            </CustomTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://localhost:3000/assets/icon-32.svg" />
        <bt:Image id="Icon.32x32" DefaultValue="https://localhost:3000/assets/icon-32.svg" />
        <bt:Image id="Icon.80x80" DefaultValue="https://localhost:3000/assets/icon-80.svg" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="Commands.Url" DefaultValue="https://localhost:3000/src/index.html" />
        <bt:Url id="Taskpane.Url" DefaultValue="https://localhost:3000/src/index.html" />
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://github.com/user/word-ai-addin" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="AI 写作助手" />
        <bt:String id="Group.Label" DefaultValue="AI 写作" />
        <bt:String id="CustomTab.Label" DefaultValue="AI 写作助手" />
        <bt:String id="Sidebar.Button.Label" DefaultValue="打开 AI 助手" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="使用 AI 快速生成、续写、改写文档内容" />
        <bt:String id="Sidebar.Button.Description" DefaultValue="打开 AI 写作助手侧栏" />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
